#!/usr/bin/env bash

f=3 b=4
for j in f b; do
	for i in {0..7}; do
		printf -v $j$i %b "\e[${!j}${i}m"
	done
done
for i in {0..7}; do
	printf -v fbright$i %b "\e[9${i}m"
	printf -v bbright$i %b "\e[10${i}m"
done
d=$'\e[1m'
t=$'\e[0m'
v=$'\e[7m'

cat <<EOF
$f0🬞🬭🬭🬭🬏$t $f1🬞🬭🬭🬭🬏$t $f2🬞🬭🬭🬭🬏$t $f3🬞🬭🬭🬭🬏$t $f4🬞🬭🬭🬭🬏$t $f5🬞🬭🬭🬭🬏$t $f6🬞🬭🬭🬭🬏$t $f7🬞🬭🬭🬭🬏$t
$f0▐$b0$fbright0▐$f0$bbright0󰮯▐$t$f0▌$t $f1▐$b1$fbright1▐$f1$bbright1󰮯▐$t$f1$t$f1▌$t $f2▐$b2$fbright2▐$f2$bbright2󰮯▐$t$f2$t$f2▌$t $f3▐$b3$fbright3▐$f3$bbright3󰮯▐$t$f3$t$f3▌$t $f4▐$b4$fbright4▐$f4$bbright4󰮯▐$t$f4$t$f4▌$t $f5▐$b5$fbright5▐$f5$bbright5󰮯▐$t$f5$t$f5▌$t $f6▐$b6$fbright6▐$f6$bbright6󰮯▐$t$f6$t$f6▌$t $f7▐$b7$fbright7▐$f7$bbright7󰮯▐$t$f7$t$f7▌$t
$f0▐$b0$fbright0$f0█$fbright0╍$t$f0▌$t $f1▐$b1$fbright1$f1█$fbright1╍$t$f1▌$t $f2▐$b2$fbright2$f2█$fbright2╍$t$f2▌$t $f3▐$b3$fbright3$f3█$fbright3╍$t$f3▌$t $f4▐$b4$fbright4$f4█$fbright4╍$t$f4▌$t $f5▐$b5$fbright5$f5█$fbright5╍$t$f5▌$t $f6▐$b6$fbright6$f6█$fbright6╍$t$f6▌$t $f7▐$b7$fbright7$f7█$fbright7╍$t$f7▌$t
$f0🬁🬂🬂🬂🬀$t $f1🬁🬂🬂🬂🬀$t $f2🬁🬂🬂🬂🬀$t $f3🬁🬂🬂🬂🬀$t $f4🬁🬂🬂🬂🬀$t $f5🬁🬂🬂🬂🬀$t $f6🬁🬂🬂🬂🬀$t $f7🬁🬂🬂🬂🬀$t
EOF
