#!/bin/sh
# vim: set nowrap:

CNAMES=(BLACK RED GREEN YELLOW BLUE MAGENTA CYAN WHITE)

RESET="\e[0m"
F=3 B=4 BF=9 BB=10
for i in {0..7}; do
  printf -v  ${CNAMES[$i]}   %b "\e[${F}${i}m"
  printf -v  ${CNAMES[$i]}BG %b "\e[${B}${i}m"
  printf -v L${CNAMES[$i]}   %b "\e[${BF}${i}m"
  printf -v L${CNAMES[$i]}BG %b "\e[${BB}${i}m"
done


MEM=$(mem '${mb_used} ${mb_total}' | xargs printf "%'dM / %'dM")

WM=$(wm)
UPTIME=$(upt)
PACKAGES=$(pkgs '${pkgs_total}')
TERMINAL=$(echo $TERM | sd ^xterm- '')
SHELL=$(basename "$SHELL")
HOSTNAME=$(cat /etc/hostname)

USER_INFO_LEN=$((${#HOSTNAME} + ${#USER} + 1))

USER_INFO="${LYELLOW}${USER}${WHITE}@${LCYAN}${HOSTNAME}"

USER_INFO_UNDERLINE=$(printf "%0.sâ–”" $(seq 1 $USER_INFO_LEN))

HW_INFO=$(gum style \
  --padding "0 1" \
  --border-foreground 10 \
  --border thick "\
${LYELLOW}ó°Ś˘  Lenovo ThinkPad X1 Yoga 4
${LBLUE}ď’Ľ  Intel Core i5-8265U
${LMAGENTA}î‰¦  ${MEM}
${LCYAN}ó°ą‘  1920x1080
${LRED}ó°„‰  ${UPTIME}")

SW_INFO=$(gum style \
  --padding "0 1" \
  --border-foreground 10 \
  --border thick "\
${LYELLOW}ď‚…  Arch Linux
${LBLUE}îŻ«  ${WM}
${LMAGENTA}ó°Ź—  ${PACKAGES}
${LCYAN}ď’‰  ${TERMINAL}
${LRED}ď„   ${SHELL}")

INFO=$(gum join --horizontal "${HW_INFO}" "${SW_INFO}")
COLOR=$(gbc)

RIGHT=$(gum style \
  --margin "0 0 0 2" \
  --align center "\
${USER_INFO}
${USER_INFO_UNDERLINE}
${INFO}
${COLOR}")

ART=$(eye)

OUT=$(gum join --horizontal --align center "${ART}" "${RIGHT}")

gum style --padding "0 0 1 0" "${OUT}"

exit 0
