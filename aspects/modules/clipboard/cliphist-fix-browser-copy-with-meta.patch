+func isBrowserImageFallback(input []byte) bool {
+	s := string(input)
+	const meta = "<meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\">"
+	if !strings.HasPrefix(s, meta) {
+		return false
+	}
+	rest := strings.TrimSpace(s[len(meta):])
