#!/usr/bin/env bash

# Approximates the phase of the moon using a known new-moon time and a fixed lunar phase of 2551443 seconds.
# Outputs the phase as an emoji in UTF-8

CHARS=(
	"ΌΟΞ" #  0 - NEW

  "ΌΟΟ" #  1 - WAXING CRESCENT
	"ΌΟΠ" #  2 - WAXING CRESCENT
	"ΌΟΡ" #  3 - WAXING CRESCENT
	"ΌΟΣ" #  4 - WAXING CRESCENT
	"ΌΟΤ" #  5 - WAXING CRESCENT
  "ΌΟΥ" #  6 - WAXING CRESCENT

	"ΌΟΦ" #  7 - FIRST QUARTER

  "ΌΟΧ" #  8 - WAXING GIBBOUS
  "ΌΟΨ" #  9 - WAXING GIBBOUS
	"ΌΟΩ" # 10 - WAXING GIBBOUS
	"ΌΟα" # 11 - WAXING GIBBOUS
	"ΌΟβ" # 12 - WAXING GIBBOUS
	"ΌΟγ" # 13 - WAXING GIBBOUS

	"ΌΟδ" # 14 - FULL
  "ΌΟδ" # 15 - FULL

	"ΌΟε" # 16 - WANING GIBBOUS
	"ΌΟζ" # 17 - WANING GIBBOUS
	"ΌΟη" # 18 - WANING GIBBOUS
	"ΌΟθ" # 19 - WANING GIBBOUS
	"ΌΟι" # 20 - WANING GIBBOUS
	"ΌΟκ" # 21 - WANING GIBBOUS

	"ΌΟλ" # 22 - LAST QUARTER

	"ΌΟμ" # 23 - WANING CRESCENT
	"ΌΟν" # 24 - WANING CRESCENT
	"ΌΟξ" # 25 - WANING CRESCENT
	"ΌΟο" # 26 - WANING CRESCENT
	"ΌΟπ" # 27 - WANING CRESCENT
	"ΌΟρ" # 28 - WANING CRESCENT

	"ΌΟΞ" # 29 - NEW
)

PHASE=$(( ( ( $( date --date='00:00' +%s ) - 1386030360 ) % 2551443 ) / 86400 ))
echo -ne "${CHARS[$PHASE]}"
if [ -z "$NONEWLINE" ]
then
	echo
fi
